{
  // Format on save with Prettier. Prettier is a devDependency, so everyone
  // formats with the same version rather than whatever each machine happens
  // to have installed globally.
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "prettier.requireConfig": true,

  // Per-language, so a formatter set globally by another extension cannot
  // quietly take over the file types this repo cares about.
  "[typescript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[typescriptreact]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[javascript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[json]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[jsonc]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[css]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[markdown]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[yaml]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },

  // .gitattributes normalizes to LF. Without this, editing on Windows writes
  // CRLF and every touched line shows as changed.
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,

  // ESLint fixes that Prettier does not do (unused imports, hook rules) are
  // left to an explicit action rather than running on every save, so a save
  // never rewrites logic - only layout.
  "editor.codeActionsOnSave": {},

  // Use the repo's TypeScript, not the one bundled with the editor, so
  // IntelliSense agrees with `npm run build`. Renamed from the deprecated
  // `typescript.tsdk`.
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "search.exclude": {
    "**/.next": true,
    "**/storybook-static": true,
    "**/package-lock.json": true
  }
}
