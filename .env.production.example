# ──────────────────────────────────────────────────────────────────────────
# Production environment — the variables to set in Vercel (Production scope).
#
# Neon's Vercel integration already provides the database vars, so you do NOT
# set these yourself: DATABASE_URL (pooled, used at runtime),
# DATABASE_URL_UNPOOLED / POSTGRES_URL_NON_POOLING (used for migrations),
# plus PGHOST, NEON_PROJECT_ID, etc. The app and migrator pick the right ones
# automatically. Everything below is what's left to configure.
# ──────────────────────────────────────────────────────────────────────────

# --- Auth (BetterAuth) -------------------------------------------------------
BETTER_AUTH_SECRET=            # generate: openssl rand -base64 32
# Auth lives on the app subdomain. With NEXT_PUBLIC_ROOT_DOMAIN set below, the
# session cookie is shared across *.flagon.io, so one login works on the
# dashboard, the API, and the sudo console.
BETTER_AUTH_URL=https://app.flagon.io

# --- Public URLs / subdomain routing ----------------------------------------
NEXT_PUBLIC_APP_URL=https://app.flagon.io
NEXT_PUBLIC_API_URL=https://api.flagon.io/v1
NEXT_PUBLIC_SUDO_URL=https://sudo.flagon.io
# Enables host-based routing (app./api./sudo.) in proxy.ts.
NEXT_PUBLIC_ROOT_DOMAIN=flagon.io

# --- Platform behavior -------------------------------------------------------
WAITLIST_ENABLED=true
MULTI_TENANCY=true
# Bootstrap admin: can reach /sudo before the sudo org exists.
FLAGON_ADMIN_EMAIL=you@flagon.io
# The sudo organization (its members get the admin console + dogfooding switch).
SUDO_ORG_SLUG=flagon

# --- Bundle store (flag delivery hot path) -----------------------------------
# Use Cloudflare R2 in production for edge-fast reads; "postgres" also works.
BUNDLE_STORE_DRIVER=r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=flagon-bundles

# --- Email (transactional) ---------------------------------------------------
RESEND_API_KEY=
# Use your verified domain in production so deliverability + reputation are good.
EMAIL_FROM=Flagon <noreply@flagon.io>

# --- Social login (optional) -------------------------------------------------
# Buttons enable automatically once a provider's pair is set; leave blank to
# keep them visible-but-disabled in the UI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# --- Billing (Stripe) — roadmap ---------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_TEAMS=
STRIPE_PRICE_ENTERPRISE=
STRIPE_METER_EVALUATIONS=
