{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run db:provision && npm run db:migrate && npm run build",
  "crons": [
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/compact",
      "schedule": "17 * * * *"
    },
    {
      "path": "/api/cron/reconcile-config",
      "schedule": "*/5 * * * *"
    }
  ],
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}
