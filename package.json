{
  "name": "flagon",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:up": "docker compose up -d --wait && npm run db:provision && npm run db:migrate",
    "db:down": "docker compose down",
    "db:provision": "node scripts/db-provision.mjs",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:studio": "drizzle-kit studio",
    "org:claim": "node scripts/org-claim.mjs",
    "stripe:listen": "docker compose up -d stripe && docker compose logs -f stripe",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "logo": "node scripts/build-logo-assets.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@icons-pack/react-simple-icons": "^13.13.0",
    "@radix-ui/react-dialog": "^1.1.20",
    "@radix-ui/react-label": "^2.1.12",
    "@radix-ui/react-select": "^2.3.4",
    "@radix-ui/react-slot": "^1.3.0",
    "@sentry/nextjs": "^10.67.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "better-auth": "^1.6.23",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.25.0",
    "next": "16.2.10",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.3.1",
    "stripe": "^22.3.2"
  },
  "devDependencies": {
    "@storybook/nextjs-vite": "^10.5.3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24.13.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prettier": "^3.9.6",
    "storybook": "^10.5.3",
    "tailwindcss": "^4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true,
    "esbuild@0.18.20": true,
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true
  }
}
