# Root domain used by src/proxy.ts to map subdomains onto route segments:
#   www / apex  -> marketing
#   app.<domain>/<org> -> /app/<org>
#   api.<domain>/...   -> /api/...
# Leave unset to default to "flagon.io". Set this to self-host under your own
# domain. On a single-domain deployment you can ignore subdomains and reach the
# app and API by path (/app, /api).
NEXT_PUBLIC_ROOT_DOMAIN=flagon.io

# Absolute base URLs for cross-surface links (see src/lib/urls.ts). Set these in
# production so a link from one subdomain to another resolves to the right host.
# Leave unset for local dev / single-domain self-host (links stay relative).
NEXT_PUBLIC_MARKETING_URL=https://www.flagon.io
NEXT_PUBLIC_APP_URL=https://app.flagon.io
NEXT_PUBLIC_API_URL=https://api.flagon.io

# Database.
# - DATABASE_URL_APP: the app connects as the restricted, RLS-enforced role
#   (flagon_app). Kept separate from any provider-injected DATABASE_URL (which
#   points at the OWNER) so the app never connects as the owner.
# - DATABASE_URL_OWNER: migrations + role provisioning run as the owner. Falls
#   back to DATABASE_URL_UNPOOLED / DATABASE_URL (e.g. Neon's injected vars).
# `npm run db:up` starts local Postgres via compose.
DATABASE_URL_APP=postgres://flagon_app:flagon_app@127.0.0.1:5432/flagon
DATABASE_URL_OWNER=postgres://flagon_owner:flagon_owner@127.0.0.1:5432/flagon
# Set to 1 when DATABASE_URL_APP points at a pooled endpoint (Neon PgBouncer);
# also auto-detected when the host contains "pooler".
# DATABASE_POOLED=1
#
# Neon + Vercel: install the Neon integration and let it inject its vars
# (POSTGRES_URL, POSTGRES_URL_NON_POOLING, PGHOST, ...). Those are the OWNER.
# Then set ONE secret, FLAGON_APP_PASSWORD, and the app connection for
# flagon_app is derived automatically from POSTGRES_URL. On each deploy,
# `npm run db:provision` creates/updates flagon_app to match, then migrations
# run. No connection strings to hand-build, no manual SQL.
# FLAGON_APP_PASSWORD=choose-a-strong-password

# BetterAuth. Generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=generate-a-long-random-secret
# Where auth is served (production: the app subdomain). When this host is on
# NEXT_PUBLIC_ROOT_DOMAIN, the session cookie is scoped to the apex
# (.flagon.io) so one sign-in covers www, app, and api. Off that domain
# (localhost, *.vercel.app previews) the session stays single-origin.
BETTER_AUTH_URL=http://localhost:3000

# Outbound email (password reset + email verification), see src/lib/email.ts.
# Providers are pluggable; Resend (https://resend.com) is the one wired up
# today. Leave RESEND_API_KEY unset to disable delivery: messages are printed
# to the server logs instead, which keeps local dev and minimal self-hosts
# fully functional (copy the link out of the logs).
# RESEND_API_KEY=re_...
# From address for outbound email. Defaults to "Flagon <noreply@flagon.io>".
# EMAIL_FROM="Flagon <noreply@yourdomain.example>"

# Stripe billing. Presence of STRIPE_SECRET_KEY turns billing ON (plan
# selection, free-tier limits, Pro via Checkout); leave unset for the
# self-host default: billing off, no plans, everything unmetered. See
# src/lib/billing.ts. Use sandbox keys (sk_test_...) everywhere until launch.
# The publishable key is not needed (hosted Stripe Checkout only).
# STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret for /api/webhooks/stripe. Locally: run
# `npm run stripe:listen` (dockerized Stripe CLI) and copy the whsec_...
# it prints. In production: from the dashboard webhook endpoint.
# STRIPE_WEBHOOK_SECRET=whsec_...
# Price id for the Pro subscription ($20/mo flat).
# STRIPE_PRO_PRICE_ID=price_...

# Enables the daily maintenance sweep at /api/cron/cleanup (expired sessions
# and verification tokens, stale rate-limit counters). Vercel's cron sends
# `Authorization: Bearer <CRON_SECRET>` automatically once this is set;
# self-hosts point their own scheduler at the endpoint with the same header.
# Generate with: openssl rand -base64 32
# CRON_SECRET=generate-a-long-random-secret
