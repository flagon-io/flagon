# ──────────────────────────────────────────────────────────────────────────
# Flagon environment configuration. Copy to `.env` and fill in.
# ──────────────────────────────────────────────────────────────────────────

# --- Database (Neon in prod; any Postgres for local/self-host) ---------------
# Pooled connection used by the app at runtime.
DATABASE_URL=postgres://flagon:flagon@localhost:5432/flagon
# Direct (non-pooled) connection used by migrations.
DIRECT_DATABASE_URL=postgres://flagon:flagon@localhost:5432/flagon

# --- Auth (BetterAuth) -------------------------------------------------------
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=dev-secret-change-me-please-use-32-bytes
BETTER_AUTH_URL=http://localhost:3000

# Platform admin (manages the waitlist). Optional: if unset, the founder (the
# first account created) is the admin. Set this to pin admin to a known email.
# FLAGON_ADMIN_EMAIL=you@yourdomain.com

# Waitlist mode. OFF (default) = open registration, great for local/self-host.
# ON = public signup is replaced by an approval waitlist (founder + approved
# emails only). Turn on in production.
WAITLIST_ENABLED=false
# Client mirror of WAITLIST_ENABLED (drives the CTA label + /signup mode). Keep in sync.
NEXT_PUBLIC_WAITLIST_ENABLED=false

# Multitenancy. ON (default) = users create/join organizations.
# Set to false for single-org mode: every user is auto-added to one shared org
# and onboarding is skipped (handy locally). RLS behaves the same either way.
MULTI_TENANCY=true
# Slug of the shared org used when MULTI_TENANCY=false.
DEFAULT_ORG_SLUG=default
# The "sudo" organization. Its members get the internal admin console and can
# switch between it and the normal app (dogfooding). Defaults to "flagon".
SUDO_ORG_SLUG=flagon

# --- Public URLs -------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
# Internal admin console ("sudo"). Leave empty locally (served at /sudo); set to
# https://sudo.flagon.io in production where it runs on its own subdomain.
# NEXT_PUBLIC_SUDO_URL=https://sudo.flagon.io
# Root domain for subdomain routing in production (app.<domain>, api.<domain>).
# Leave UNSET locally so the proxy is a no-op and literal paths work.
# NEXT_PUBLIC_ROOT_DOMAIN=flagon.io

# --- Bundle store (flag delivery hot path) -----------------------------------
# "postgres" (default; great for local + self-host) or "r2" (Cloudflare R2 / S3).
BUNDLE_STORE_DRIVER=postgres
# Required when BUNDLE_STORE_DRIVER=r2:
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=flagon-bundles
# Optional explicit endpoint (defaults to https://<account>.r2.cloudflarestorage.com)
R2_ENDPOINT=

# --- Email (transactional: invites, password reset, waitlist) ----------------
# Provider-agnostic. With no key set, emails are logged to the console (dev).
# EMAIL_PROVIDER=resend            # "resend" (default if key set) or "log"
RESEND_API_KEY=
# From address. IMPORTANT: the onboarding@resend.dev sandbox sender lands in
# spam (shared domain, no DKIM/SPF alignment to you). The moment you have a
# Resend-verified domain, switch to an address on it so DKIM+SPF align. Also add
# a DMARC record (see below) — Gmail effectively requires it.
EMAIL_FROM=Flagon <noreply@flagon.io>
# Send test emails without hurting deliverability using Resend's test inboxes:
#   delivered@resend.dev · bounced@resend.dev · complained@resend.dev
#   https://resend.com/docs/dashboard/emails/send-test-emails
# Deliverability checklist (DNS in Cloudflare, "DNS only" / grey cloud):
#   1. Resend domain verified → DKIM (resend._domainkey) + SPF (send.) records. ✓
#   2. DMARC: add TXT  _dmarc.flagon.io  ->  v=DMARC1; p=none; rua=mailto:dmarc@flagon.io
#      (Resend doesn't add this; Gmail/Yahoo bulk rules want it. Missing DMARC is a
#       common spam cause even with SPF+DKIM passing.)
#   3. From: must be @flagon.io (a sandbox/shared sender like resend.dev = spam).

# --- Social login (optional) -------------------------------------------------
# Set a provider's id + secret and its "Continue with…" button enables itself,
# no code change. Leave blank to keep the buttons visible but disabled.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# --- Billing (Stripe), roadmap -----------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_TEAMS=
STRIPE_PRICE_ENTERPRISE=
STRIPE_METER_EVALUATIONS=
